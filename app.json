{
  "expo": {
    "name": "HeoDatBeo",
    "slug": "HeoDatBeo",
    "version": "4.0.0",
    "orientation": "portrait",
    "icon": "./assets/savepig.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/savepig.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/savepig.jpg",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.expomobile87.HeoDatBeo"
    },
    "web": {
      "favicon": "./assets/savepig.jpg"
    },
    "plugins": ["expo-sharing", "@react-native-community/datetimepicker"]
  }
}
